#!/bin/sh
set -eu

if [ "$(id -u)" -ne 0 ]; then
  echo "This initializer must run as root." >&2
  exit 1
fi

install -d -o root -g root -m 0700 /etc/esense-midnight
umask 077
seed="$(openssl rand -hex 32)"
issuer="$(openssl rand -hex 32)"
password="Esense-$(openssl rand -hex 32)-2026!"
temporary="$(mktemp /etc/esense-midnight/preprod.env.XXXXXX)"

{
  echo "MIDNIGHT_NETWORK=preprod"
  echo "MIDNIGHT_PREPROD_SEED=$seed"
  echo "MIDNIGHT_ISSUER_SECRET=$issuer"
  echo "MIDNIGHT_PRIVATE_STATE_PASSWORD=$password"
  echo "MIDNIGHT_PROOF_SERVER=http://127.0.0.1:6300"
  echo "MIDNIGHT_WALLET_STATE_DIR=/var/lib/esense-midnight/state/wallet-cache"
  echo "MIDNIGHT_SYNC_TIMEOUT_MS=21600000"
  echo "MIDNIGHT_SYNC_CHECKPOINT_MS=300000"
} > "$temporary"

chown root:root "$temporary"
chmod 0600 "$temporary"
mv "$temporary" /etc/esense-midnight/preprod.env
echo "Preprod service identity initialized."
